# grossberg-rag — environment variables
#
# Keys are loaded from TWO places (project .env does NOT override the global one):
#   1) ~/.oh-my-zsh/custom/apikey.env   (loaded first)
#   2) ./.env                            (loaded with override=False)
# So you can put the keys in either file. Copy this to .env and fill in,
# or keep them in your global apikey.env.

# --- Required: LLM / Embedding providers ---
# Google Gemini — KG extraction, vision, embedding, and (optional) answer provider
GOOGLE_API_KEY=your-google-api-key

# OpenAI — final answer synthesis when answer.provider=openai (gpt-5.5)
OPENAI_API_KEY=your-openai-api-key

# --- Optional: Arize AX tracing ---
# Required only when TRACING=1. Get them at https://app.arize.com (Settings > API Keys / Spaces)
ARIZE_API_KEY=your-arize-api-key
ARIZE_SPACE_ID=your-arize-space-id

# --- Optional: feature flags ---
# Enable Arize OpenInference tracing (CHAIN/LLM/EMBEDDING spans). Default off.
TRACING=0

# Log full prompt/response in logs/llm_calls.jsonl instead of truncated previews. Default off.
LLM_LOG_FULL=0

# Note: non-secret settings (PDF path, storage dirs, parser, model names, rerank,
# answer provider) live in config.yaml — not here.
